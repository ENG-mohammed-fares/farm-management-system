<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartfarm.controller.LoginController"
            prefWidth="900" prefHeight="550"
            style="-fx-background-color: #2E7D32; -fx-padding: 0;"
            stylesheets="@../css/login.css">

   <VBox fx:id="leftPanel"
         AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0"
         AnchorPane.bottomAnchor="0"
         prefWidth="380"
         styleClass="left-panel"
         spacing="15" alignment="CENTER_LEFT">

      <padding>
         <Insets top="40" right="50" bottom="40" left="50"/>
      </padding>

      <Label text="Welcome Back" styleClass="welcome-label"/>
      <Label text="Log In" styleClass="title-label"/>

      <Label text="Email or Phone" styleClass="field-label"/>
      <TextField fx:id="emailField"
                 promptText="Enter your email or phone"
                 styleClass="input-field"/>

      <Label text="Password" styleClass="field-label"/>
      <HBox spacing="5" alignment="CENTER_LEFT">
         <PasswordField fx:id="passwordField"
                        promptText="Enter your password"
                        styleClass="input-field"
                        HBox.hgrow="ALWAYS"/>
         <TextField fx:id="visiblePasswordField"
                    promptText="Enter your password"
                    styleClass="input-field"
                    visible="false"
                    managed="false"
                    HBox.hgrow="ALWAYS"/>
         <Button text="👁"
                 styleClass="show-hide-btn"
                 onAction="#handleShowHidePassword"/>
      </HBox>

      <Label fx:id="errorLabel" styleClass="error-label"/>

      <Button fx:id="loginButton"
              text="Log In"
              styleClass="login-btn"
              onAction="#handleLogin"
              maxWidth="Infinity"/>

      <HBox alignment="CENTER" spacing="5">
         <Label text="Don't have an account?" styleClass="small-label"/>
         <Hyperlink text="Sign Up"
                    styleClass="signup-link"
                    onAction="#handleSignUp"/>
      </HBox>

   </VBox>

   <StackPane fx:id="rightPanel"
              AnchorPane.rightAnchor="0"
              AnchorPane.topAnchor="0"
              AnchorPane.bottomAnchor="0"
              prefWidth="520"
              styleClass="right-panel">

      <VBox alignment="TOP_CENTER" spacing="15">
         <padding>
            <Insets top="40"/>
         </padding>

         <Label fx:id="greetingLabel" styleClass="greeting-label"/>

         <VBox alignment="CENTER" spacing="5">
            <Label fx:id="projectNameLabel" styleClass="project-name-label"/>
            <Label text="Management System" styleClass="project-sub-label"/>
            <Label text="Version 1.0" styleClass="version-label"/>
         </VBox>

         <Label fx:id="statsLabel" styleClass="stats-label"/>

      </VBox>

      <VBox alignment="BOTTOM_CENTER" spacing="10">
         <padding>
            <Insets bottom="60"/>
         </padding>
         <Label fx:id="smartFarmLabel" text="Smart Farm Management" styleClass="right-title"/>
         <Label text="Manage your farm smarter" styleClass="right-subtitle"/>
      </VBox>

      <ImageView fitWidth="420" fitHeight="350"
                 preserveRatio="true"
                 pickOnBounds="true">
         <image>
            <Image url="@../images/colorful-farmer-collection-removebg-preview.png"/>
         </image>
      </ImageView>

   </StackPane>

   <Button fx:id="themeToggleBtn"
           styleClass="theme-btn"
           AnchorPane.topAnchor="-40"
           AnchorPane.leftAnchor="-40"
           onAction="#handleThemeToggle">
      <graphic>
         <ImageView fx:id="themeIcon" fitWidth="120" fitHeight="120">
            <image>
               <Image url="@../images/sun.png"/>
            </image>
         </ImageView>
      </graphic>
   </Button>

</AnchorPane>